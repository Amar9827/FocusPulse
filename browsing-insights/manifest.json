{
  "manifest_version": 3,
  "name": "Browsing Insights",
  "version": "0.4.0",
  "description": "Tracks your daily browsing and generates AI-powered insights about your day.",

  "permissions": [
    "storage",
    "tabs",
    "idle",
    "alarms",
    "scripting",
    "activeTab"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Browsing Insights"
  },

  "options_page": "options.html",

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "host_permissions": [
    "https://openrouter.ai/*",
    "https://api.groq.com/*"
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
